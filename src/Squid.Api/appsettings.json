{
  "AllowedHosts": "*",
  "ApiRunMode": "Api",
  "Serilog": {
    "Application": "Squid.Api",
    "Seq": {
      "ServerUrl": "http://localhost:5341",
      "ApiKey": ""
    }
  },
  "RedisCacheConnectionString": "127.0.0.1:6379,password=,ssl=False,abortConnect=False,syncTimeout=50000,allowAdmin=true",
  "SquidStore": {
    "ConnectionString": "Host=127.0.0.1;Database=squid;Username=postgres;Password=123456"
  },
  "SelfCert": {
    "Base64": "",
    "Password": ""
  },
  "AllowableCorsOrigins": "http://localhost:3000",
  "Authentication": {
    "Jwt": {
      "SymmetricKey": "change-this-squid-dev-key-to-a-long-random-secret",
      "UserTokenExpiryHours": 24
    }
  },
  "Security": {
    "VariableEncryption": {
      "MasterKey": ""
    }
  },
  "PollingListener": {
    "Port": 10943,
    "Enabled": false
  }
}
